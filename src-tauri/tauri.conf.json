{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Sleep Scoring",
  "version": "0.3.0",
  "identifier": "com.sleepscoring.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sleep Scoring",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* http://192.168.0.0/16:* http://10.0.0.0/8:* http://172.16.0.0/12:* https://github.com https://objects.githubusercontent.com; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:",
      "devtools": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFM0E5OTIzRDcwMDI4NUMKUldSY0tBRFhJNWs2YnFYTmpCbUp5YWdDcjFxdTcrdFRUYXpIa0c3WmoxNERjcFhUQWRBc3prQTAK",
      "endpoints": [
        "https://github.com/uzaira0-internal-testing/sleep-scoring-web/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
